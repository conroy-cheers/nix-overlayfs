 }
 
 
+static IMAGE_BASE_RELOCATION *get_base_relocation_end( char *base, IMAGE_NT_HEADERS *nt,
+                                                       IMAGE_DATA_DIRECTORY *dir, SIZE_T total_size,
+                                                       IMAGE_SECTION_HEADER *sections )
+{
+    IMAGE_BASE_RELOCATION *end = (IMAGE_BASE_RELOCATION *)(base + dir->VirtualAddress + dir->Size);
+
+#ifdef __aarch64__
+    IMAGE_DATA_DIRECTORY *loadcfg;
+    const IMAGE_LOAD_CONFIG_DIRECTORY *cfg;
+    ULONG sec, offset, size;
+
+    if (!(loadcfg = get_data_dir( nt, total_size, IMAGE_DIRECTORY_ENTRY_LOAD_CONFIG ))) return end;
+    cfg = (const IMAGE_LOAD_CONFIG_DIRECTORY *)(base + loadcfg->VirtualAddress);
+    size = min( loadcfg->Size, cfg->Size );
+    if (size <= offsetof( IMAGE_LOAD_CONFIG_DIRECTORY, DynamicValueRelocTableSection )) return end;
+    sec = cfg->DynamicValueRelocTableSection;
+    offset = cfg->DynamicValueRelocTableOffset;
+    if (!sec || sec > nt->FileHeader.NumberOfSections) return end;
+    if (offset >= sections[sec - 1].Misc.VirtualSize) return end;
+    if (sections[sec - 1].VirtualAddress + offset <= dir->VirtualAddress) return end;
+
+    end = min( end, (IMAGE_BASE_RELOCATION *)(base + sections[sec - 1].VirtualAddress + offset) );
+#endif
+
+    return end;
+}
